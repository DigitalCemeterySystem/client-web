# Локальный демо-режим без серверной части.
DCS_DEMO_MODE=true
NEXT_PUBLIC_DCS_DEMO_MODE=true
SESSION_COOKIE_SECURE=false

# Локальный полный режим с настоящим API Gateway.
# Для запуска через Docker Compose обычно используется http://api-gateway:8080.
# Для запуска клиента напрямую рядом с серверной частью обычно используется http://localhost:8080.
API_URL=http://localhost:8080
NEXT_PUBLIC_API_URL=http://localhost:8080

# Старое перенаправление /api/* на серверную часть.
# Обычно не нужно, потому что API проксируются через Route Handlers.
DCS_LEGACY_API_REWRITES=false
